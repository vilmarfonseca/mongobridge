# Used by mongobridge — copy to .env and fill in (never commit .env)

# Required: MongoDB database name (not passed on the CLI)
MONGOBRIDGE_DB=myapp

# Aliases (optional): same meaning as MONGOBRIDGE_DB if you prefer an existing name
# MONGOBRIDGE_DEFAULT_DB=myapp
# MONGO_DB_NAME=myapp

# Primary profiles
MONGO_LOCAL_URI=mongodb://localhost:27017
MONGO_ATLAS_URI=mongodb+srv://user:pass@cluster.mongodb.net

# Optional aliases (any can be used as --from / --to: staging, production, local, atlas)
MONGO_STAGING_DB_URL=
MONGO_PRODUCTION_DB_URL=

# Optional: remote default for pull/push when you use profile "remote"
# MONGO_REMOTE_URI=
